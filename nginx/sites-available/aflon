server {
    listen 80;
    server_name main.aflon.com.ng;
    return 301 https://$host$request_uri;
}



server {
    listen 443 ssl http2;
    server_name main.aflon.com.ng;

    ssl_certificate /etc/letsencrypt/live/main.aflon.com.ng/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/main.aflon.com.ng/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;

    # Add tenant header based on subdomain
    # Example: unilesa.aflon.com.ng → tenant=unilesa
       set $tenant "";
       if ($host ~* "^([^.]+)\.aflon\.com\.ng$") {
        set $tenant $1;
       }
       proxy_set_header X-Sakai-Tenant $tenant;

    }
}

